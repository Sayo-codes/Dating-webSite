############################################################
# Environment configuration for Next.js + Prisma + Neon
#
# 1. Copy this file to `.env` in the project root:
#       cp .env.example .env
# 2. Fill in the real values from your Neon and PayPal dashboards.
############################################################

# PostgreSQL (Neon) – Prisma uses this as `datasource db.url`
# Get this from Neon → Project → Connection details (Prisma connection string).
# It should usually include `?sslmode=require`.
#
# Example (DO NOT USE AS‑IS):
# postgresql://USER:PASSWORD@ep-your-neon-host.eu-central-1.aws.neon.tech:5432/yourdb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@ep-your-neon-host.eu-central-1.aws.neon.tech:5432/yourdb?sslmode=require"

# Optional: direct / non‑pooled URL for migrations (if Neon provides it).
# If you only have one URL from Neon, you can duplicate DATABASE_URL here.
DIRECT_URL="postgresql://USER:PASSWORD@ep-your-neon-direct-host.eu-central-1.aws.neon.tech:5432/yourdb?sslmode=require"

# JWT secret for auth tokens (any strong random string in dev; keep secret in prod)
JWT_SECRET="change-me-in-production"

# Socket / app origin (for real‑time messaging; adjust when using LAN or deploy)
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
NEXT_PUBLIC_APP_ORIGIN="http://localhost:3000"

############################################################
# PayPal – required for premium payments
############################################################

# Frontend: used by the PayPal React SDK on the Premium page.
NEXT_PUBLIC_PAYPAL_CLIENT_ID="your-paypal-client-id"

# Backend: used by `src/shared/lib/paypal.ts` to talk to the PayPal REST API.
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"

# Optional: set to "false" to use live instead of sandbox.
# PAYPAL_SANDBOX="true"

# Optional: webhook verification (if you wire up webhooks)
# PAYPAL_WEBHOOK_ID="your-paypal-webhook-id"

############################################################
# S3 / uploads (optional – only needed if you want media uploads)
############################################################

# S3_BUCKET=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_PUBLIC_URL=""
# S3_REGION=""
# S3_ENDPOINT=""

# Copy this file to .env and set your values.
# Required: DATABASE_URL so Prisma can connect to PostgreSQL.

# Database (required). For Neon: use pooled URL here and direct URL below.
DATABASE_URL="postgresql://user:password@localhost:5432/website?connect_timeout=15"
# For Neon: direct connection (host without -pooler). Leave unset for local Postgres.
# DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require&connect_timeout=15"

# Auth (use a long random string in production)
JWT_SECRET="dev-secret-change-in-production"

# Optional: agency “invite code”. When set, logged-in users can POST it at /join-admin
# to become admin (share URL /join-admin + this secret separately). Generate e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ADMIN_INVITE_SECRET=""

# Socket server (real-time chat)
SOCKET_PORT=3001
SOCKET_SERVER_URL="http://localhost:3001"
SOCKET_SERVER_SECRET=""
# Shown in browser; must match where the app is served
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
NEXT_PUBLIC_APP_ORIGIN="http://localhost:3000"

# PayPal (optional – payments work only when set; use sandbox for testing)
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_WEBHOOK_ID=""
PAYPAL_SANDBOX="true"
NEXT_PUBLIC_PAYPAL_CLIENT_ID=""

# S3 / uploads (optional – presign and uploads fail gracefully if not set)
S3_REGION="us-east-1"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL=""
# S3_ENDPOINT=""
# S3_FORCE_PATH_STYLE="false"
